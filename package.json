{
  "name": "vita-os",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "VitaOS monorepo — Operator, Tom, Tim apps, MCP servers, workers, and shared packages.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check . && eslint --max-warnings=0 .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,yaml,yml}\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "changeset": "changeset",
    "release": "changeset publish",
    "version-packages": "changeset version",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.9",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "lefthook": "^1.8.2",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
