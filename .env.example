# =============================================================================
# VitaOS env example. Copy to .env.local for dev. See runbooks/secret-rotation.md
# for rotation cadences. Variables prefixed NEXT_PUBLIC_ are client-visible.
# =============================================================================

# --- Runtime --------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- Supabase -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Postgres direct, used by workers / Drizzle migrations) -----
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Redis ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO local, S3 in prod) -----------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vita-l0

# --- Search ---------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# --- AI providers ---------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Payments / billing ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Voice / telephony ----------------------------------------------------
VAPI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Integration broker ---------------------------------------------------
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_HOST=https://api.nango.dev

# --- Error monitoring -----------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Telemetry ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=vita-os
HONEYCOMB_API_KEY=

# --- Email ----------------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM=noreply@example.com
