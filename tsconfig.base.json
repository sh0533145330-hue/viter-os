{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": false,

    "baseUrl": ".",
    "paths": {
      "@vita/core": ["packages/core/src/index.ts"],
      "@vita/core/*": ["packages/core/src/*"],
      "@vita/agents": ["packages/agents/src/index.ts"],
      "@vita/agents/*": ["packages/agents/src/*"],
      "@vita/blocks-builtin": ["packages/blocks-builtin/src/index.ts"],
      "@vita/agents-builtin": ["packages/agents-builtin/src/index.ts"],
      "@vita/pack-sdk": ["packages/pack-sdk/src/index.ts"],
      "@vita/packs-seed": ["packages/packs-seed/src/index.ts"],
      "@vita/packs-seed/*": ["packages/packs-seed/src/*"],
      "@vita/connector-sdk": ["packages/connector-sdk/src/index.ts"],
      "@vita/connectors-builtin": ["packages/connectors-builtin/src/index.ts"],
      "@vita/ui": ["packages/ui/src/index.ts"],
      "@vita/auth": ["packages/auth/src/index.ts"],
      "@vita/policy": ["packages/policy/src/index.ts"],
      "@vita/anonymization": ["packages/anonymization/src/index.ts"],
      "@vita/branding": ["packages/branding/src/index.ts"],
      "@vita/billing": ["packages/billing/src/index.ts"],
      "@vita/voice": ["packages/voice/src/index.ts"],
      "@vita/timeseries": ["packages/timeseries/src/index.ts"],
      "@vita/eval": ["packages/eval/src/index.ts"],
      "@vita/db": ["packages/db/src/index.ts"],
      "@vita/observability": ["packages/observability/src/index.ts"],
      "@vita/observability/*": ["packages/observability/src/*"],
      "@vita/config": ["packages/config/src/index.ts"],
      "@vita/config/*": ["packages/config/src/*"],
      "@vita/ontology": ["packages/ontology/src/index.ts"],
      "@vita/ontology/*": ["packages/ontology/src/*"],
      "@vita/key-custody": ["packages/key-custody/src/index.ts"],
      "@vita/key-custody/*": ["packages/key-custody/src/*"],
      "@vita/security": ["packages/security/src/index.ts"],
      "@vita/security/*": ["packages/security/src/*"],
      "@vita/test-harness": ["packages/test-harness/src/index.ts"],
      "@vita/test-harness/*": ["packages/test-harness/src/*"],
      "@vita/search": ["packages/search/src/index.ts"],
      "@vita/search/*": ["packages/search/src/*"],
      "@vita/approvals": ["packages/approvals/src/index.ts"],
      "@vita/approvals/*": ["packages/approvals/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo", "coverage"]
}
