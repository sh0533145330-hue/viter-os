{
  "name": "@vita/config",
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Zod-validated environment loader for VitaOS apps and workers.",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" },
    "./env": { "types": "./src/env.ts", "import": "./src/env.ts" }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
