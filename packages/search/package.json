{
  "name": "@vita/search",
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Hybrid search and answer engine: Meilisearch + pgvector + RRF + reranker + LLM synthesis with citations and lineage.",
  "private": true,
  "main": "./src/index.ts",
