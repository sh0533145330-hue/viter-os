{
  "name": "@vita/db",
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Drizzle schemas, migrations, storage abstraction for the VitaOS substrate (L0-L4).",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    },
    "./relations": {
      "types": "./src/relations.ts",
      "import": "./src/relations.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    }
  },
  "files": ["dist", "src", "migrations", "policies"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "tsx scripts/generate.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
