{
  "name": "@vita/core",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "VitaOS core SDK: defineBlock, defineWire, runtime contracts.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "jsonata": "^2.2.0",
    "zod": "^3.23.8"
  }
}
